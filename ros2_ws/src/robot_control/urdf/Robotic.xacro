<joint name="Revolute 2" type="continuous">
  <origin xyz="0 0 0.097755" rpy="0 0 0"/> <parent link="base_link"/>
  <child link="Component2_1"/>
  <axis xyz="0.0 0.0 1.0"/>
</joint>

<joint name="Revolute 3" type="continuous">
  <origin xyz="-0.150 -0.0505 0.160" rpy="0 1.57 1.57"/>
  <parent link="Component2_1"/>
  <child link="Component3_1"/>
  <axis xyz="0 0 1"/> 
</joint>

<joint name="Revolute 4" type="continuous">
  <origin xyz="-0.350 0 0" rpy="0 0 -1.172"/>
  <parent link="Component3_1"/>
  <child link="Component4_1"/>
  <axis xyz="0 0 1"/>
</joint>

<joint name="Revolute 5" type="revolute">
  <origin xyz="0.221 -0.045 0.047" rpy="0 0 0"/> <parent link="Component4_1"/>
  <child link="Component5_1"/>
  <axis xyz="0 0 1"/> 
  <limit lower="-1.57" upper="1.57" effort="100" velocity="1.0"/>
</joint>

<joint name="Revolute 6" type="revolute">
  <origin xyz="0.1 -0.06 -0.01" rpy="0 0 0"/> 
  <parent link="Component5_1"/>
  <child link="Component6_1"/>
  <axis xyz="0 1 0"/> <limit lower="-1.57" upper="1.57" effort="100" velocity="1.0"/>
</joint>

<joint name="Revolute 7" type="revolute">
  <origin xyz="0 -0.15 0.02" rpy="0 1.5708 -1.5708"/> 
  <parent link="Component6_1"/>
  <child link="Component7_1"/>
  <axis xyz="0 0 1"/> 
  <limit lower="-3.14" upper="3.14" effort="100" velocity="1.0"/>
</joint>

<joint name="Revolute 8" type="revolute"> 
  <origin xyz="-0.018 0 0.05" rpy="1.5708 0 1.5708"/> 
  <parent link="Component7_1"/>
  <child link="Component8_1"/>
  <axis xyz="0 0 1"/> 
  <limit lower="-0.5" upper="0.5" effort="50" velocity="0.5"/>
</joint>

<joint name="Revolute 9" type="revolute">
  <origin xyz="-0.013 0 0.05" rpy="-1.5708 0 -1.5708"/>
  <parent link="Component7_1"/>
  <child link="Component8_Mirror__1"/>
  <axis xyz="0 0 -1"/>
  <limit lower="-0.5" upper="0.5" effort="50" velocity="0.5"/>
</joint>
</robot>

