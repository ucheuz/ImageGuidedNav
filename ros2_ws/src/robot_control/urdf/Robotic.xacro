  <inertial>
    <origin xyz="-0.037229257165138384 0.04065002788003971 0.018985873388544516" rpy="0 0 0"/>
    <mass value="9.99270875492589"/>
    <inertia ixx="0.048518" iyy="0.021455" izz="0.043108" ixy="0.00925" iyz="0.012379" ixz="-0.002929"/>
