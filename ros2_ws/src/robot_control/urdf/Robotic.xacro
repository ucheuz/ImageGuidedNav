<?xml version="1.0" ?>
<robot name="Robotic" xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:include filename="$(find robot_control)/urdf/materials.xacro" />
<xacro:include filename="$(find robot_control)/urdf/Robotic.trans" />
<xacro:include filename="$(find robot_control)/urdf/Robotic.gazebo" />

<link name="world"/>

<joint name="world_joint" type="fixed">
  <parent link="world"/>
  <child link="base_link"/>
  <origin xyz="0 0 0" rpy="0 0 0"/>
</joint>

<link name="base_link">
  <inertial>
    <origin xyz="0.0007806396519895978 -0.0007806396451176682 0.04859351552798209" rpy="0 0 0"/>
    <mass value="12.47367775880617"/>
    <inertia ixx="0.118752" iyy="0.118752" izz="0.218412" ixy="0.000272" iyz="-0.000713" ixz="0.000713"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://robot_control/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://robot_control/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

