    <origin xyz="-0.2 0.3 -0.01" rpy="1.5708 0 -1.5708"/>
    <geometry>
      <mesh filename="package://robot_control/meshes/Component5_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
