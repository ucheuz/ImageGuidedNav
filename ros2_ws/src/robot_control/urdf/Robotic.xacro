<link name="Component8_Mirror__1">
  <inertial>
    <origin xyz="0.009343421801771373 0.02316394746506706 -0.022928258768890597" rpy="0 0 0"/>
    <mass value="0.17272823257156844"/>
    <inertia ixx="0.000115" iyy="2.2e-05" izz="0.000111" ixy="-2.2e-05" iyz="2.8e-05" ixz="6e-06"/>
