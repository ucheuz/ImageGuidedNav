<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="Robotic">
    <xacro:arg name="initial_positions_file" default="initial_positions.yaml" />

    <!-- Import Robotic urdf file -->
    <xacro:include filename="$(find robot_control)/urdf/Robotic.xacro" />

    <!-- Import control_xacro -->
    <xacro:include filename="Robotic.ros2_control.xacro" />


    <xacro:Robotic_ros2_control name="FakeSystem" initial_positions_file="$(arg initial_positions_file)"/>

</robot>
